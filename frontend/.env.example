# Copy this file to .env.local and fill in the values.

# Base URL of the FastAPI backend.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Auth.js (NextAuth) session secret.
# Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Google OAuth client credentials (Google Cloud Console > APIs & Services > Credentials).
# Create an "OAuth client ID" of type "Web application" and add these redirect URIs:
#   Dev:  http://localhost:3000/api/auth/callback/google
#   Prod: https://YOUR_DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# In production (non-Vercel hosts), also set the canonical app URL:
# AUTH_URL=https://YOUR_DOMAIN
